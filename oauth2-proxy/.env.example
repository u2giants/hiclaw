# oauth2-proxy credentials — copy this file to .env and fill in the values.
# The .env file is never committed. Get actual values from the Authentik admin UI
# or from whoever manages auth.designflow.app.

# From Authentik: Admin UI → Applications → HiClaw → Edit Provider → Client ID
OAUTH2_CLIENT_ID=

# From Authentik: Admin UI → Applications → HiClaw → Edit Provider → Client Secret
OAUTH2_CLIENT_SECRET=

# A random 32-byte base64 string used to sign the oauth2-proxy session cookie.
# Generate one with:   python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# If you lose or rotate this, all existing sessions are invalidated (users must log in again).
OAUTH2_PROXY_COOKIE_SECRET=
