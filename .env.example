# HiClaw Environment Variables
# Copy this to .env and fill in real values

# Admin credentials
HICLAW_ADMIN_USER=admin
HICLAW_ADMIN_PASSWORD=<REPLACE_ME>
HICLAW_MINIO_PASSWORD=<REPLACE_ME>

# LLM / AI provider (currently OpenRouter)
HICLAW_LLM_PROVIDER=openai-compat
HICLAW_LLM_API_KEY=<REPLACE_ME>                         # sk-or-v1-...
HICLAW_OPENAI_BASE_URL=https://openrouter.ai/api/v1
HICLAW_DEFAULT_MODEL=deepseek/deepseek-v4-pro
HICLAW_EMBEDDING_MODEL=text-embedding-v4

# Embedding / AI gateway
HICLAW_AI_GATEWAY_URL=http://aigw-local.hiclaw.io:8080
HICLAW_AI_GATEWAY_ADMIN_URL=http://127.0.0.1:8001

# Controller / Manager wiring
HICLAW_CONTROLLER_URL=http://hiclaw-controller:8090
HICLAW_CMS_SERVICE_NAME=hiclaw-manager
HICLAW_MANAGER_NAME=default
HICLAW_MANAGER_RUNTIME=openclaw
HICLAW_MANAGER_ENABLED=true
HICLAW_DEFAULT_WORKER_RUNTIME=openclaw
HICLAW_WORKER_IMAGE=higress-registry.cn-hangzhou.cr.aliyuncs.com/higress/hiclaw-worker:v1.1.0

# Manager auth
HICLAW_MANAGER_GATEWAY_KEY=<REPLACE_ME>
HICLAW_MANAGER_PASSWORD=<REPLACE_ME>
HICLAW_AUTH_TOKEN=<REPLACE_ME>                          # long-lived JWT

# Object storage (MinIO)
HICLAW_FS_ENDPOINT=http://hiclaw-controller:9000
HICLAW_FS_ACCESS_KEY=default
HICLAW_FS_SECRET_KEY=<REPLACE_ME>
HICLAW_FS_BUCKET=hiclaw-storage
HICLAW_STORAGE_PREFIX=hiclaw/hiclaw-storage

# Matrix / Element
HICLAW_MATRIX_DOMAIN=matrix-local.hiclaw.io:18080
HICLAW_MATRIX_URL=http://127.0.0.1:6167
HICLAW_ELEMENT_HOMESERVER_URL=http://127.0.0.1:18080

# Google OAuth (oauth2-proxy + Tuwunel Matrix SSO)
GOOGLE_CLIENT_ID=<REPLACE_ME>                           # xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<REPLACE_ME>                       # GOCSPX-...
OAUTH2_PROXY_COOKIE_SECRET=<REPLACE_ME>                 # random 32-byte base64 string
GOOGLE_ADMIN_EMAIL=<REPLACE_ME>

# Docker / host paths
HICLAW_DOCKER_NETWORK=hiclaw-net
HICLAW_HOST_SHARE_DIR=/home/ai
HICLAW_WORKSPACE_DIR=/worksp/hiclaw/workspace

# For container-local overrides (hiclaw-controller has different endpoints)
# HICLAW_FS_ENDPOINT=http://127.0.0.1:9000
# HICLAW_MINIO_ENDPOINT=http://127.0.0.1:9000
